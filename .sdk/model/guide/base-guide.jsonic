# Guide

guide: {
  metrics: count: entity: 1
  metrics: count: path: 2
  metrics: count: method: 2

  entity: coordinate_conversion: {
    path: "/bng2latlong/{easting}/{northing}": {
      op: load: method: *GET
    }
    path: "/bng2latlong/{easting}/{northing}/xml": {
      op: load: method: *GET
    }
  }

}